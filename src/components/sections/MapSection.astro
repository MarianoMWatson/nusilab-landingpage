---
import { clinics } from '../../data/clinics.js';
---
<section class="section section-surface" id="donde-puede-participar" aria-labelledby="map-h2">
  <div class="container">

    <div class="map-header" data-reveal>
      <p class="overline">
        <span class="overline-rule" aria-hidden="true"></span>
        <span>Dónde puede participar</span>
      </p>
      <h2 id="map-h2">9 centros habilitados en Argentina</h2>
      <p class="map-sub">
        Centros autorizados por ANMAT en CABA, Buenos Aires, Córdoba, Santa Fe y Tucumán.
      </p>
    </div>

    <div class="map-layout">

      <!-- Map container -->
      <div class="map-wrap" aria-label="Mapa de centros del estudio">
        <div id="study-map" class="study-map" role="application" aria-label="Mapa interactivo de centros"></div>
      </div>

      <!-- Clinic cards -->
      <div class="clinics-list" aria-label="Lista de centros participantes">
        {clinics.map((c, i) => (
          <button
            class="clinic-card"
            data-lat={c.coords[0]}
            data-lng={c.coords[1]}
            data-index={i}
            type="button"
            aria-label={`${c.name}, ${c.address}, ${c.city}`}
          >
            <div class="clinic-card-top">
              <span class="clinic-status status-recruiting">Reclutando</span>
              <span class="clinic-city">{c.city}</span>
            </div>
            <h3 class="clinic-name">{c.name}</h3>
            <p class="clinic-addr">{c.address}, CP {c.cp}</p>
          </button>
        ))}
      </div>

    </div>

  </div>
</section>

<script is:inline define:vars={{ clinicsData: clinics }}>
  window.__mapClinics = clinicsData;
</script>

<script>
  import '../../scripts/map.js';
</script>

<style>
  .map-header {
    max-width: 600px;
    margin-bottom: var(--sp-10);
  }

  .map-sub {
    font-size: var(--text-sm);
    color: var(--text-2);
    margin: 0;
  }

  /* ── Layout ────────────────────────────────────────────── */
  .map-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }

  @media (min-width: 1024px) {
    .map-layout {
      grid-template-columns: 1fr 340px;
      gap: var(--sp-8);
      align-items: start;
    }
  }

  /* ── Map ───────────────────────────────────────────────── */
  .map-wrap {
    border-radius: var(--r-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
  }

  .study-map {
    height: 420px;
    background: var(--bg-card);
  }

  @media (min-width: 768px) {
    .study-map { height: 520px; }
  }

  /* ── Clinic cards list ─────────────────────────────────── */
  .clinics-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    max-height: 520px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border-mid) transparent;
  }

  /* ── Clinic card ───────────────────────────────────────── */
  .clinic-card {
    width: 100%;
    text-align: left;
    background: var(--bg-card);
    border: none;
    cursor: pointer;
    padding: var(--sp-4) var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    transition: background var(--t-fast);
    font-family: var(--font-ui);
  }

  .clinic-card:hover,
  .clinic-card.active { background: var(--bg-elevated); }

  .clinic-card.active {
    border-left: 2px solid var(--accent);
    padding-left: calc(var(--sp-5) - 2px);
  }

  .clinic-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-2);
    margin-bottom: var(--sp-1);
  }

  .clinic-city {
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .clinic-name {
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-1);
    line-height: var(--lh-tight);
  }

  .clinic-addr {
    font-size: 12px;
    color: var(--text-3);
    margin: 0;
    line-height: 1.4;
  }
</style>
