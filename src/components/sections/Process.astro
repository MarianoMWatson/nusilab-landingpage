---
const steps = [
  {
    n: '1',
    phase: 'Preselección',
    title: 'Complete el cuestionario en línea',
    body: 'Responda unas pocas preguntas para saber si reúne los requisitos básicos. Toma menos de 5 minutos y no compromete a nada.',
  },
  {
    n: '2',
    phase: 'Contacto',
    title: 'El equipo del estudio lo contactará',
    body: 'Si cumple los criterios preliminares, un coordinador del centro más cercano se comunicará con usted para explicarle los próximos pasos y agendar una visita.',
  },
  {
    n: '3',
    phase: 'Visita de selección',
    title: 'Visita médica en el centro',
    body: 'Un médico evaluará su salud, responderá todas sus preguntas y le pedirá que firme el consentimiento informado. Si todo está bien, quedará inscripto.',
  },
  {
    n: '4',
    phase: 'Participación',
    title: 'Reciba la vacuna y realice el seguimiento',
    body: 'Recibirá la vacuna y asistirá a entre 2 y 4 visitas de seguimiento a lo largo de aproximadamente un año. Toda la atención médica relacionada es sin costo.',
  },
];
---
<section class="section section-surface" id="que-pasara-en-este-estudio" aria-labelledby="process-h2">
  <div class="container">

    <div class="process-header" data-reveal>
      <p class="overline">
        <span class="overline-rule" aria-hidden="true"></span>
        <span>Qué pasará en este estudio</span>
      </p>
      <h2 id="process-h2">El proceso, paso a paso</h2>
    </div>

    <ol class="process-steps" aria-label="Pasos del proceso de participación">
      {steps.map(s => (
        <li class="process-step" data-reveal>
          <div class="step-ghost-n" aria-hidden="true">{s.n}</div>
          <div class="step-inner">
            <div class="step-meta">
              <span class="step-phase">{s.phase}</span>
              <span class="step-num-badge" aria-hidden="true">{s.n}</span>
            </div>
            <h3 class="step-title">{s.title}</h3>
            <p class="step-body">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>

  </div>
</section>

<style>
  .process-header {
    max-width: 560px;
    margin-bottom: var(--sp-12);
  }

  /* ── Steps list ────────────────────────────────────────── */
  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-2);
    counter-reset: step;
  }

  @media (min-width: 1024px) {
    .process-steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      overflow: hidden;
    }
  }

  /* ── Step card ─────────────────────────────────────────── */
  .process-step {
    position: relative;
    padding: var(--sp-8) var(--sp-6);
    background: var(--bg-card);
    border-radius: var(--r-lg);
    overflow: hidden;
    transition: background var(--t-fast);
  }

  @media (min-width: 1024px) {
    .process-step {
      border-radius: 0;
      padding: var(--sp-10) var(--sp-8);
    }
    .process-step:hover { background: var(--bg-elevated); }
  }

  /* ── Ghost number (editorial treatment) ────────────────── */
  .step-ghost-n {
    position: absolute;
    top: -16px;
    right: 16px;
    font-family: var(--font-display);
    font-size: 120px;
    font-weight: 300;
    line-height: 1;
    color: var(--text-1);
    opacity: 0.03;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
  }

  /* ── Step inner ────────────────────────────────────────── */
  .step-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .step-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .step-phase {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-2);
  }

  .step-num-badge {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--accent-2-mid);
    background: var(--accent-2-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent-2);
  }

  .step-title {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-1);
    line-height: var(--lh-tight);
    letter-spacing: -0.01em;
  }

  .step-body {
    font-size: var(--text-sm);
    color: var(--text-2);
    line-height: var(--lh-body);
    margin: 0;
  }

  /* ── Connector line on desktop ─────────────────────────── */
  @media (min-width: 1024px) {
    .process-step:not(:last-child)::after {
      display: none; /* handled by grid gap+border */
    }
  }
</style>
