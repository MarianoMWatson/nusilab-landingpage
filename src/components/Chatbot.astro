---
---

<!-- ── Floating chatbot button ── -->
<button
  class="chat-fab"
  id="chat-fab"
  aria-label="Abrir asistente virtual"
  aria-expanded="false"
>
  <span class="chat-fab-icon" id="chat-fab-icon-open" aria-hidden="true">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="8" width="18" height="13" rx="2"/>
      <circle cx="9"  cy="14" r="1.5" fill="currentColor" stroke="none"/>
      <circle cx="15" cy="14" r="1.5" fill="currentColor" stroke="none"/>
      <path d="M9 18h6"/>
      <path d="M12 3v5"/>
      <circle cx="12" cy="3" r="1" fill="currentColor" stroke="none"/>
      <path d="M3 13H1M23 13h-2"/>
    </svg>
  </span>
  <span class="chat-fab-icon" id="chat-fab-icon-close" style="display:none" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M5 5l10 10M15 5L5 15"/>
    </svg>
  </span>
  <span class="chat-fab-badge" id="chat-fab-badge" aria-label="1 mensaje nuevo">1</span>
</button>

<!-- ── Chat window ── -->
<div class="chat-window" id="chat-window" style="display:none" role="dialog" aria-label="Asistente virtual NUSI-001">

  <!-- Header -->
  <div class="chat-header">
    <div class="chat-header-left">
      <div class="chat-avatar" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="8" width="18" height="13" rx="2"/>
          <circle cx="9"  cy="14" r="1.5" fill="currentColor" stroke="none"/>
          <circle cx="15" cy="14" r="1.5" fill="currentColor" stroke="none"/>
          <path d="M9 18h6"/>
          <path d="M12 3v5"/>
          <circle cx="12" cy="3" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <div>
        <p class="chat-bot-name">Asistente NUSI-001</p>
        <p class="chat-bot-status">
          <span class="chat-status-dot" aria-hidden="true"></span>
          Sin conexión
        </p>
      </div>
    </div>
    <button class="chat-close-btn" id="chat-close-btn" type="button" aria-label="Cerrar chat">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M5 5l10 10M15 5L5 15"/>
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div class="chat-messages" id="chat-messages" aria-live="polite"></div>

  <!-- Input -->
  <form class="chat-input-row" id="chat-form" novalidate>
    <input
      class="chat-input"
      id="chat-input"
      type="text"
      placeholder="Escriba su mensaje…"
      autocomplete="off"
      aria-label="Escribir mensaje"
      maxlength="300"
    />
    <button type="submit" class="chat-send-btn" aria-label="Enviar mensaje">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/>
      </svg>
    </button>
  </form>

</div>

<script is:inline>
(function () {
  var FORMSPREE = 'https://formspree.io/f/YOUR_FORMSPREE_FORM_ID';

  var fab       = document.getElementById('chat-fab');
  var chatWin   = document.getElementById('chat-window');
  var closeBtn  = document.getElementById('chat-close-btn');
  var form      = document.getElementById('chat-form');
  var input     = document.getElementById('chat-input');
  var messages  = document.getElementById('chat-messages');
  var badge     = document.getElementById('chat-fab-badge');
  var iconOpen  = document.getElementById('chat-fab-icon-open');
  var iconClose = document.getElementById('chat-fab-icon-close');
  var isOpen    = false;
  var offlineFormShown = false;
  var offlineFormSubmitted = false;
  var submittedName = '';

  var S = {
    input: 'width:100%;box-sizing:border-box;padding:9px 12px;background:#13101E;border:1px solid rgba(255,255,255,0.12);border-radius:10px;color:#F0EDF8;font-family:Inter,system-ui,sans-serif;font-size:13px;outline:none;',
    btn:   'width:100%;padding:10px 16px;background:#76E5FC;color:#0C0A14;border:none;border-radius:10px;font-family:Inter,system-ui,sans-serif;font-size:13px;font-weight:700;cursor:pointer;margin-top:4px;',
  };

  // ── Seed initial messages ──────────────────────────────────
  addMsg('Hola 👋 Soy el asistente virtual del estudio NUSI-001. Estoy aquí para responder sus preguntas sobre el estudio.', 'bot');

  // ── Open / close ───────────────────────────────────────────
  function openChat() {
    isOpen = true;
    chatWin.style.display = 'flex';
    chatWin.classList.remove('chat-win--closing');
    chatWin.classList.add('chat-win--open');
    fab.setAttribute('aria-expanded', 'true');
    iconOpen.style.display = 'none';
    iconClose.style.display = 'flex';
    badge.style.display = 'none';
    input.focus();
  }

  function closeChat() {
    isOpen = false;
    chatWin.classList.remove('chat-win--open');
    chatWin.classList.add('chat-win--closing');
    fab.setAttribute('aria-expanded', 'false');
    iconOpen.style.display = 'flex';
    iconClose.style.display = 'none';
    chatWin.addEventListener('animationend', function handler() {
      chatWin.style.display = 'none';
      chatWin.classList.remove('chat-win--closing');
      chatWin.removeEventListener('animationend', handler);
      // Reset para que la próxima apertura empiece desde cero
      messages.innerHTML = '';
      offlineFormShown = false;
      offlineFormSubmitted = false;
      submittedName = '';
      addMsg('Hola 👋 Soy el asistente virtual del estudio NUSI-001. Estoy aquí para responder sus preguntas sobre el estudio.', 'bot');
    });
  }

  fab.addEventListener('click', function () { isOpen ? closeChat() : openChat(); });
  closeBtn.addEventListener('click', function (e) { e.stopPropagation(); closeChat(); });

  // ── addMsg ─────────────────────────────────────────────────
  function addMsg(html, role, warn) {
    var wrap = document.createElement('div');
    wrap.style.cssText = 'display:flex;flex-direction:column;gap:3px;max-width:88%;' +
      (role === 'user' ? 'align-self:flex-end;align-items:flex-end;' : 'align-self:flex-start;align-items:flex-start;');

    var bubble = document.createElement('div');
    bubble.style.cssText = 'padding:10px 14px;border-radius:16px;font-size:13px;line-height:1.55;font-family:Inter,system-ui,sans-serif;' +
      (role === 'user'
        ? 'background:#76E5FC;color:#0C0A14;border-bottom-right-radius:4px;'
        : warn
          ? 'background:rgba(251,191,36,0.05);color:#C0BCD0;border:1px solid rgba(251,191,36,0.2);border-bottom-left-radius:4px;'
          : 'background:#221E30;color:#C0BCD0;border:1px solid rgba(255,255,255,0.07);border-bottom-left-radius:4px;');
    bubble.innerHTML = html;

    var time = document.createElement('span');
    time.style.cssText = 'font-size:10px;color:#7B759E;font-family:Inter,system-ui,sans-serif;padding:0 4px;';
    time.textContent = 'ahora';

    wrap.appendChild(bubble);
    wrap.appendChild(time);
    messages.appendChild(wrap);
    messages.scrollTop = messages.scrollHeight;
  }

  // ── Offline form bubble ────────────────────────────────────
  function showOfflineForm(prefill) {
    if (offlineFormShown) {
      // Solo actualiza el textarea si ya está visible
      var ta = document.getElementById('ol-msg');
      if (ta && prefill) ta.value = prefill;
      return;
    }
    offlineFormShown = true;

    var wrap = document.createElement('div');
    wrap.style.cssText = 'align-self:flex-start;align-items:flex-start;max-width:95%;display:flex;flex-direction:column;gap:3px;';

    var bubble = document.createElement('div');
    bubble.style.cssText = 'background:#1A1627;border:1px solid rgba(118,229,252,0.15);border-radius:16px;border-bottom-left-radius:4px;padding:16px;font-family:Inter,system-ui,sans-serif;';
    bubble.innerHTML =
      '<p style="margin:0 0 12px;font-size:13px;font-weight:600;color:#F0EDF8;">Dejanos tus datos y tu consulta:</p>' +
      '<div style="display:flex;flex-direction:column;gap:10px;">' +
        '<input id="ol-name" type="text" placeholder="Nombre y apellido" style="' + S.input + '"/>' +
        '<input id="ol-contact" type="text" placeholder="Teléfono o correo electrónico" style="' + S.input + '"/>' +
        '<textarea id="ol-msg" rows="3" placeholder="¿Cuál es tu consulta?" style="' + S.input + 'resize:none;">' + (prefill || '') + '</textarea>' +
        '<button id="ol-submit" style="' + S.btn + '">Enviar consulta →</button>' +
        '<p id="ol-error" style="display:none;margin:0;font-size:12px;color:#f87171;"></p>' +
      '</div>';

    wrap.appendChild(bubble);
    messages.appendChild(wrap);
    messages.scrollTop = messages.scrollHeight;

    // Eventos del formulario inline
    bubble.querySelectorAll('input, textarea').forEach(function(el) {
      el.addEventListener('focus', function() { el.style.borderColor = '#76E5FC'; });
      el.addEventListener('blur',  function() { el.style.borderColor = 'rgba(255,255,255,0.12)'; });
    });

    document.getElementById('ol-submit').addEventListener('click', function() {
      var btn     = document.getElementById('ol-submit');
      var nameVal = (document.getElementById('ol-name').value || '').trim();
      var contactVal = (document.getElementById('ol-contact').value || '').trim();
      var msgVal  = (document.getElementById('ol-msg').value || '').trim();
      var errEl   = document.getElementById('ol-error');

      if (!nameVal || !contactVal || !msgVal) {
        errEl.textContent = 'Por favor completá todos los campos.';
        errEl.style.display = 'block';
        return;
      }
      errEl.style.display = 'none';
      btn.textContent = 'Enviando…';
      btn.disabled = true;

      fetch(FORMSPREE, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ nombre: nameVal, contacto: contactVal, consulta: msgVal, origen: 'chatbot-offline' }),
      })
      .then(function(r) {
        var firstName = nameVal.split(' ')[0];
        offlineFormSubmitted = true;
        submittedName = firstName;
        bubble.innerHTML =
          '<div style="text-align:center;padding:8px 0;">' +
            '<p style="font-size:22px;margin:0 0 8px;">✓</p>' +
            '<p style="margin:0;font-size:13px;color:#F0EDF8;font-weight:600;">¡Consulta recibida!</p>' +
            '<p style="margin:6px 0 0;font-size:12px;color:#9E98BA;">' + firstName + ', te respondemos a la brevedad al contacto que nos indicaste.</p>' +
          '</div>';
        messages.scrollTop = messages.scrollHeight;
      })
      .catch(function() {
        btn.textContent = 'Error — intentá de nuevo';
        btn.disabled = false;
      });
    });
  }

  // ── Typing indicator ───────────────────────────────────────
  function showTyping() {
    var wrap = document.createElement('div');
    wrap.id = 'chat-typing';
    wrap.style.cssText = 'align-self:flex-start;';
    wrap.innerHTML =
      '<div style="display:flex;align-items:center;gap:5px;padding:12px 16px;background:#221E30;border:1px solid rgba(255,255,255,0.07);border-radius:16px;border-bottom-left-radius:4px;">' +
        '<span class="chat-dot"></span><span class="chat-dot"></span><span class="chat-dot"></span>' +
      '</div>';
    messages.appendChild(wrap);
    messages.scrollTop = messages.scrollHeight;
  }

  function removeTyping() {
    var t = document.getElementById('chat-typing');
    if (t) t.remove();
  }

  // ── User sends message while offline ──────────────────────
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var text = input.value.trim();
    if (!text) return;
    addMsg(text, 'user');
    input.value = '';
    showTyping();
    setTimeout(function () {
      removeTyping();
      if (offlineFormSubmitted) {
        addMsg(submittedName + ', ya recibimos tu consulta. Te responderemos a la brevedad.', 'bot', true);
      } else {
        addMsg('⚠️ <strong style="color:#F0EDF8;">El asistente no está disponible en este momento.</strong> Dejá tu consulta y te respondemos a la brevedad.', 'bot', true);
        showOfflineForm(text);
      }
      messages.scrollTop = messages.scrollHeight;
    }, 900);
  });
})();
</script>

<style is:global>
  .chat-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 200;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--bg-base);
    box-shadow: 0 4px 20px rgba(118,229,252,0.35);
    transition: transform 150ms, box-shadow 150ms;
  }
  .chat-fab:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 28px rgba(118,229,252,0.5);
  }
  .chat-fab-icon { display:flex; align-items:center; justify-content:center; line-height:0; }

  .chat-fab-badge {
    position: absolute;
    top: 4px; right: 4px;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: #f87171;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    font-family: Inter, system-ui, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--bg-base);
  }

  .chat-window {
    position: fixed;
    bottom: calc(24px + 56px + 12px);
    right: 24px;
    z-index: 199;
    width: min(370px, calc(100vw - 32px));
    height: min(520px, calc(100dvh - 160px));
    background: var(--bg-card);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.6);
    flex-direction: column;
    overflow: hidden;
    transform-origin: bottom right;
  }

  .chat-win--open {
    animation: chatIn 0.28s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
  }
  .chat-win--closing {
    animation: chatOut 0.18s ease-in forwards;
  }

  @keyframes chatIn {
    from { opacity: 0; transform: translateY(20px) scale(0.93); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }
  @keyframes chatOut {
    from { opacity: 1; transform: translateY(0)    scale(1); }
    to   { opacity: 0; transform: translateY(20px) scale(0.93); }
  }

  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    background: var(--bg-elevated);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    flex-shrink: 0;
  }
  .chat-header-left { display:flex; align-items:center; gap:10px; }
  .chat-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: var(--accent-dim);
    border: 1px solid var(--border-accent);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }
  .chat-bot-name {
    font-size: 13px; font-weight: 600; color: var(--text-1);
    font-family: Inter, system-ui, sans-serif; margin: 0; line-height: 1.2;
  }
  .chat-bot-status {
    font-size: 11px; color: var(--text-3);
    font-family: Inter, system-ui, sans-serif; margin: 0;
    display: flex; align-items: center; gap: 5px;
  }
  .chat-status-dot {
    width: 7px; height: 7px; border-radius: 50%; background: #6b7280; flex-shrink: 0;
  }
  .chat-close-btn {
    width: 32px; height: 32px;
    background: none; border: none; cursor: pointer;
    color: var(--text-3); border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    transition: color 150ms, background 150ms;
  }
  .chat-close-btn:hover { color: var(--text-1); background: var(--brand-dim); }

  .chat-messages {
    flex: 1; overflow-y: auto;
    padding: 16px; display: flex;
    flex-direction: column; gap: 10px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.12) transparent;
  }

  .chat-input-row {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px;
    border-top: 1px solid rgba(255,255,255,0.07);
    background: var(--bg-elevated); flex-shrink: 0;
  }
  .chat-input {
    flex: 1;
    background: var(--bg-surface);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 20px;
    padding: 9px 16px;
    color: var(--text-1);
    font-family: Inter, system-ui, sans-serif;
    font-size: 13px; outline: none;
    transition: border-color 150ms;
  }
  .chat-input:focus { border-color: var(--accent); }
  .chat-input::placeholder { color: var(--text-3); }
  .chat-send-btn {
    width: 34px; height: 34px; flex-shrink: 0;
    border-radius: 50%; background: var(--accent);
    border: none; cursor: pointer; color: var(--bg-base);
    display: flex; align-items: center; justify-content: center;
    transition: transform 150ms;
  }
  .chat-send-btn:hover { transform: scale(1.08); }

  .chat-dot {
    display: inline-block;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--text-3);
    animation: chat-bounce 1.2s infinite ease-in-out;
  }
  .chat-dot:nth-child(2) { animation-delay: 0.2s; }
  .chat-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes chat-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30%           { transform: translateY(-6px); opacity: 1; }
  }
</style>
