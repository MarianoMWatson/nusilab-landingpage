---
export interface Props {
  title?:       string;
  description?: string;
  canonical?:   string;
}

const {
  title       = 'Estudio NUSI-001 — Vacuna contra la gripe | Nusilab',
  description = 'Inscripción abierta para adultos de 65 años o más. Estudio de investigación médica sobre una vacuna contra la gripe. Autorizado por ANMAT. Sin cobertura médica requerida.',
  canonical,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <meta name="description" content={description}/>
  <title>{title}</title>
  {canonical && <link rel="canonical" href={canonical}/>}

  <!-- Fonts: Fraunces (display) + Inter (UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;1,9..144,300&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- Design tokens + global styles -->
  <link rel="stylesheet" href="/src/styles/tokens.css"/>

  <!-- GTM — uncomment and replace GTM-XXXXXXX before launch -->
  <!--
  <script is:inline>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-XXXXXXX');
  </script>
  -->
</head>
<body>
  <!-- GTM noscript — uncomment with GTM id -->
  <!-- <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript> -->

  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

  <slot/>

  <!-- Motion (GSAP) — loaded last -->
  <script>
    import '../scripts/motion.js';
  </script>
</body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/global.css';

  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--sp-4);
    background: var(--accent);
    color: var(--bg-base);
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--r-sm);
    font-weight: 700;
    font-size: var(--text-sm);
    z-index: 9999;
    text-decoration: none;
  }
  .skip-link:focus { top: var(--sp-4); }
</style>
